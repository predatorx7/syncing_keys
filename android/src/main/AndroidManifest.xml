<manifest xmlns:android="http://schemas.android.com/apk/res/android"
  package="app.xyz.everydayapp.syncing_keys">

  <!-- Required for Google Drive REST API uploads (encrypted blobs only). -->
  <uses-permission android:name="android.permission.INTERNET" />

  <!-- Required to enumerate Google accounts when the developer's app
       requests a Drive `appdata` OAuth token via Google Identity. -->
  <uses-permission android:name="android.permission.GET_ACCOUNTS" />

  <!-- Used by local_auth (BiometricPrompt) on supported devices. -->
  <uses-permission android:name="android.permission.USE_BIOMETRIC" />
  <uses-permission android:name="android.permission.USE_FINGERPRINT" />
</manifest>
